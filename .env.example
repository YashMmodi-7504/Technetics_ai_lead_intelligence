# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APOLLO_API_KEY: Required for Apollo Live Search + one-click import.
APOLLO_API_KEY="MY_APOLLO_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# Authentication / Security
# ---------------------------------------------------------------------------
# REQUIRED in production. Generate with: openssl rand -base64 48
# Must be >= 32 chars and must NOT be the legacy 'super_secret_dev_key'.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=technetics-platform
JWT_AUDIENCE=technetics-clients

# CORS: comma-separated allowlist of browser origins. REQUIRED in production.
# e.g. https://app.technetics.com,https://admin.technetics.com
CORS_ALLOWED_ORIGINS=

# Cookie domain for the refresh-token cookie (e.g. .technetics.com). Optional.
COOKIE_DOMAIN=

# Set to 'true' ONLY in local dev to enable the /api/auth/dev-token endpoint.
ENABLE_DEV_TOKEN=false

# NODE_ENV=production enables secure cookies and strict secret validation.
NODE_ENV=development

# ---------------------------------------------------------------------------
# Cloud SQL Credentials
# ---------------------------------------------------------------------------
SQL_HOST=
SQL_USER=
SQL_PASSWORD=
SQL_DB_NAME=
SQL_PORT=5432
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Database Pool Configuration
# ---------------------------------------------------------------------------
SQL_POOL_MAX=10
SQL_IDLE_TIMEOUT_MS=30000
SQL_CONNECT_TIMEOUT_MS=15000
SQL_STATEMENT_TIMEOUT_MS=30000
# Set SQL_SSL=false only for local dev without SSL. Default: SSL enabled.
SQL_SSL=
SQL_SSL_REJECT_UNAUTHORIZED=true

# ---------------------------------------------------------------------------
# AI Cost Governance
# ---------------------------------------------------------------------------
AI_MAX_CALLS_PER_MINUTE=10
AI_MAX_TOKENS_PER_HOUR=50000
